# ─────────────────────────────────────────────
# CareerOS AI/ML Layer — Environment Variables
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────

# ── LLM Provider Keys ──────────────────────────────────────────────────────────
# Primary: Groq (https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Fallback: OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-your_openrouter_api_key_here

# ── Model Selection ─────────────────────────────────────────────────────────────
# Groq model (primary)
GROQ_MODEL=llama3-70b-8192

# OpenRouter model (fallback — free tier)
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# ── Routing & Retry Config ──────────────────────────────────────────────────────
# Seconds before a provider call is considered timed out
LLM_TIMEOUT_SECONDS=30

# How many times to retry the primary provider before falling back
LLM_MAX_RETRIES=2

# ── Logging ─────────────────────────────────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
